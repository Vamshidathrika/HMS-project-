# Local Environment Variables for Ashirwad Hospital (pixel-hms) - Template
# Copy this file to '.env' and fill in your cloud database credentials.

# Cloud PostgreSQL Database Credentials
SPRING_DATASOURCE_URL=jdbc:postgresql://<HOST>:<PORT>/<DATABASE_NAME>?sslmode=require
SPRING_DATASOURCE_USERNAME=<USERNAME>
SPRING_DATASOURCE_PASSWORD=<PASSWORD>

# Database active profiles (use 'prod' for cloud connection, 'dev' for local)
SPRING_PROFILES_ACTIVE=prod
